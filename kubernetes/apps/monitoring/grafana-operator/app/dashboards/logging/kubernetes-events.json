              "involvedObject.fieldPath": true,
              "involvedObject.resourceVersion": true,
              "involvedObject.uid": true,
              "apiVersion": true,
              "kind": true,
              "reportingComponent": true,
              "reportingInstance": true,
              "source.host": true,
              "action": true,
              "eventTime": true,
              "firstTimestamp": true
