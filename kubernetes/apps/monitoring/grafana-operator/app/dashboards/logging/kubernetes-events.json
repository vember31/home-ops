          "expr": "{reason!=\"\", type=~\"$type\"} involvedObject.namespace:~\"$namespace\" | stats by (reason) count() c | sort by (c desc) | limit 20",
          "legendFormat": "{{reason}}",
          "queryType": "stats",
          "refId": "A"
