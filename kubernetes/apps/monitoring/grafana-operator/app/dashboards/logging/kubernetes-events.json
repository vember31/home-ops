    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 12,
      "title": "Events",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "type" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-text" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Warning": { "color": "red", "index": 0 }, "Normal": { "color": "green", "index": 1 } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "reason" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          },
          {
            "matcher": { "id": "byName", "options": "involvedObject.namespace" },
            "properties": [{ "id": "custom.width", "value": 130 }, { "id": "displayName", "value": "namespace" }]
          },
          {
            "matcher": { "id": "byName", "options": "involvedObject.name" },
            "properties": [{ "id": "custom.width", "value": 220 }, { "id": "displayName", "value": "object" }]
          },
          {
            "matcher": { "id": "byName", "options": "involvedObject.kind" },
            "properties": [{ "id": "custom.width", "value": 100 }, { "id": "displayName", "value": "kind" }]
          },
          {
            "matcher": { "id": "byName", "options": "source.component" },
            "properties": [{ "id": "custom.width", "value": 160 }, { "id": "displayName", "value": "source" }]
          },
          {
            "matcher": { "id": "byName", "options": "Line" },
            "properties": [{ "id": "displayName", "value": "message" }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 170 }]
          }
        ]
      },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 23 },
      "id": 7,
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "enablePagination": true },
        "sortBy": []
      },
      "pluginVersion": "11.5.1",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "editorMode": "code",
          "expr": "{reason!=\"\", type=~\"$type\"} involvedObject.namespace:~\"$namespace\" | fields _time, type, reason, \"involvedObject.namespace\", \"involvedObject.kind\", \"involvedObject.name\", \"source.component\", _msg | sort desc | limit $limit",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "source": "labels"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "id": true,
              "tsNs": true,
              "labels": true,
              "detected_level": true
            },
            "indexByName": {
              "Time": 0,
              "type": 1,
              "reason": 2,
              "source.component": 3,
              "involvedObject.namespace": 4,
              "involvedObject.kind": 5,
              "involvedObject.name": 6,
              "Line": 7
            }
          }
        }
      ],
      "title": "Events",
      "type": "table"
    }
