        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
          "editorMode": "code",
          "expr": "{type=\"Warning\"} involvedObject.namespace:~\"$namespace\" | stats count()",
          "legendFormat": "Warnings",
          "queryType": "statsRange",
          "refId": "A"
        }
      ],
      "title": "Warning Events",
