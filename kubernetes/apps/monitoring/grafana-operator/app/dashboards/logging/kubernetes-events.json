          "queryType": "stats",
          "refId": "A"
        }
      ],
      "title": "By Namespace",
      "type": "piechart"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "mappings": [],
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 13 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] },
        "pieType": "donut",
        "tooltip": { "hideZeros": true, "mode": "single", "sort": "desc" }
      },
      "pluginVersion": "11.5.1",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "${DS_VICTORIALOGS}" },
