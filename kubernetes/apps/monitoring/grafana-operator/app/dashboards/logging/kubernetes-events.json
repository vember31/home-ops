      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "links": [
        {
          "title": "Filter to Warnings",
          "url": "/d/kubernetes-events/kubernetes-events?var-type=Warning&${__url_time_range}&var-namespace=${namespace}&var-limit=${limit}",
          "targetBlank": false
