            "renameByName": {
              "Time": "Time",
              "type": "Type",
              "source.component": "Source",
              "involvedObject.namespace": "Namespace",
              "involvedObject.kind": "Kind",
              "involvedObject.name": "Object",
              "body": "Message",
              "count": "Count",
              "lastTimestamp": "Last Seen"
            },
            "indexByName": {
              "Time": 0,
              "type": 1,
              "source.component": 2,
              "involvedObject.namespace": 3,
              "involvedObject.kind": 4,
              "involvedObject.name": 5,
              "body": 6,
              "count": 7,
              "lastTimestamp": 8
            }
          }
        }
