{
  "__inputs": [
    {
      "name": "DS_VICTORIALOGS",
      "label": "VictoriaLogs",
      "description": "",
      "type": "datasource",
      "pluginId": "victoriametrics-logs-datasource",
      "pluginName": "VictoriaLogs"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.5.1"
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    },
    {
      "type": "datasource",
      "id": "victoriametrics-logs-datasource",
      "name": "VictoriaLogs",
      "version": "0.13.1"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Kubernetes Events stream powered by VictoriaLogs",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "victoriametrics-logs-datasource",
        "uid": "${DS_VICTORIALOGS}"
      },
      "gridPos": { "h": 24, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": true,
        "showCommonLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "Event Stream",
      "type": "logs",
      "targets": [
        {
          "datasource": {
            "type": "victoriametrics-logs-datasource",
            "uid": "${DS_VICTORIALOGS}"
          },
          "expr": "{namespace=~\"$namespace\", type=~\"$type\", reason!=\"\"} | sort desc | limit 500",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kubernetes", "events"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {
          "type": "victoriametrics-logs-datasource",
          "uid": "${DS_VICTORIALOGS}"
        },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Namespace",
        "multi": false,
        "name": "namespace",
        "options": [],
        "query": {
          "field": "namespace",
          "query": "{reason!=\"\"}",
          "type": "fieldValue"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "All", "value": ".*" },
        "hide": 0,
        "includeAll": false,
        "label": "Type",
        "multi": false,
        "name": "type",
        "options": [
          { "selected": true, "text": "All", "value": ".*" },
          { "selected": false, "text": "Warning", "value": "Warning" },
          { "selected": false, "text": "Normal", "value": "Normal" }
        ],
        "query": "All : .*,Warning : Warning,Normal : Normal",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kubernetes Events",
  "uid": "kubernetes-events",
  "version": 1
}
