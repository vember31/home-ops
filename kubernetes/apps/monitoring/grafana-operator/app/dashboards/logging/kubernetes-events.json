          "expr": "{reason!=\"\", type=~\"$type\", \"involvedObject.namespace\"!=\"\"} involvedObject.namespace:~\"$namespace\" | stats by (\"involvedObject.namespace\") count() c | sort by (c desc) | limit 20",
