{
  "save_path": "/media/downloads",
  "temp_path": "/media/downloads/incomplete",
  "temp_path_enabled": true,

  "file_log_enabled": true,
  "file_log_path": "/config/qBittorrent/logs",
  "file_log_age": 1,
  "file_log_age_type": 1,
  "file_log_backup_enabled": true,
  "file_log_delete_old": true,
  "file_log_max_size": 65,

  "listen_port": 50413,
  "random_port": false,
  "upnp": false,
  "upnp_lease_duration": 0,
  "bittorrent_protocol": 0,
  "dht": true,
  "lsd": true,
  "pex": true,
  "encryption": 0,

  "max_connec": 200,
  "max_connec_per_torrent": 100,
  "max_uploads": 50,
  "max_uploads_per_torrent": 20,

  "queueing_enabled": true,
  "max_active_downloads": 10,
  "max_active_torrents": 200,
  "max_active_uploads": 200,
  "max_active_checking_torrents": 1,
  "dont_count_slow_torrents": false,

  "dl_limit": 0,
  "up_limit": 0,
  "alt_dl_limit": 10240,
  "alt_up_limit": 10240,
  "limit_utp_rate": true,
  "limit_lan_peers": true,

  "max_concurrent_http_announces": 50,
  "announce_to_all_tiers": true,
  "announce_to_all_trackers": false,
  "connection_speed": 30,

  "async_io_threads": 10,
  "disk_io_read_mode": 1,
  "disk_io_write_mode": 1,
  "memory_working_set_limit": 512,
  "request_queue_size": 500,

  "add_stopped_enabled": false,
  "torrent_content_layout": "Original",
  "torrent_content_remove_option": "Delete",
  "auto_tmm_enabled": false,
  "auto_delete_mode": 0,
  "mark_of_the_web": true,
  "resolve_peer_countries": true,
  "resume_data_storage_type": "Legacy",

  "max_ratio_enabled": false,
  "max_seeding_time_enabled": false,
  "max_inactive_seeding_time_enabled": false,

  "web_ui_address": "*",
  "web_ui_port": 8080,
  "web_ui_upnp": false,
  "web_ui_ban_duration": 3600,
  "web_ui_max_auth_fail_count": 5,
  "web_ui_session_timeout": 3600,
  "web_ui_clickjacking_protection_enabled": true,
  "web_ui_csrf_protection_enabled": true,
  "web_ui_secure_cookie_enabled": true,
  "web_ui_host_header_validation_enabled": false,
  "web_ui_domain_list": "*",
  "web_ui_reverse_proxy_enabled": false,

  "bypass_auth_subnet_whitelist": "${SECURE_CIDR}\n${POD_CIDR}\n${SERVICE_CIDR}\n${VPN_CIDR}",
  "bypass_auth_subnet_whitelist_enabled": true,
  "bypass_local_auth": true,
  "ssrf_mitigation": true
}
